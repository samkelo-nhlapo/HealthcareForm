{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "HealthcareEntity": "__SET_CONNECTIONSTRINGS__HEALTHCAREENTITY_ENV_VAR__"
  },
  "AppSettings": {
    "ClientValidationEnabled": true,
    "UnobtrusiveJavaScriptEnabled": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Jwt": {
    "Issuer": "HealthcareForm.Api",
    "Audience": "HealthcareForm.Angular",
    "Key": "__SET_JWT__KEY_ENV_VAR_MIN_32_CHARS__",
    "TokenExpiryMinutes": 60
  }
}
